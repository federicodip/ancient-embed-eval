Bootstrap: docker
From: pytorch/pytorch:2.6.0-cuda12.4-cudnn9-runtime

%files
  requirements.txt /opt/project/requirements.txt

%post
  apt-get update && apt-get install -y --no-install-recommends build-essential git && rm -rf /var/lib/apt/lists/*

  # Core Python deps (torch already in base image, pip will skip it)
  pip install --no-cache-dir -r /opt/project/requirements.txt

  # flash-attn skipped: runtime image lacks CUDA headers for compilation,
  # and the .so has mmap issues in SIF containers. 8B models fall back to
  # eager attention (slower but functional).

%environment
  export LC_ALL=C
  export PYTHONUNBUFFERED=1

%runscript
  python "$@"
